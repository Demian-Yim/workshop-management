rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Session selfies and characters: public read/write for workshop participants
    match /sessions/{sessionId}/{allPaths=**} {
      allow read, write: if true;
    }
    // Default: authenticated users only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
