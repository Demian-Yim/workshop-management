rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── 세션 코드: 조회는 공개, 생성/수정은 인증 필요 ──
    match /sessionCodes/{code} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── 과정 (Course) ──
    match /courses/{courseId} {
      // 누구나 읽기 가능, 생성/수정은 관리자만
      allow read: if true;
      allow write: if isAdmin();

      match /sessions/{sessionId} {
        // 세션 메타: 누구나 읽기, 생성/수정은 인증 사용자
        allow read: if true;
        allow write: if isAuthenticated();

        // 참가자 데이터: 워크샵 중 학습자가 직접 작성 (세션코드 인증)
        match /participants/{participantId} {
          allow read, write: if true;
        }
        match /attendance/{participantId} {
          allow read, write: if true;
        }
        match /introCards/{participantId} {
          allow read, write: if true;
        }

        // 팀 배정: 누구나 읽기, 생성/수정은 인증 사용자
        match /teams/{teamId} {
          allow read: if true;
          allow write: if isAuthenticated();
        }

        // 게시판: 참가자가 자유롭게 작성
        match /posts/{postId} {
          allow read, write: if true;
        }

        // 공지: 누구나 읽기, 생성/수정은 인증 사용자
        match /announcements/{announcementId} {
          allow read: if true;
          allow write: if isAuthenticated();
        }

        // 점심 투표: 참가자가 직접 참여
        match /lunchPoll/{pollId} {
          allow read: if true;
          allow write: if isAuthenticated();
        }
        match /lunchVotes/{participantId} {
          allow read, write: if true;
        }

        // 리뷰/설문: 참가자가 직접 작성
        match /reviews/{participantId} {
          allow read, write: if true;
        }
        match /surveyResponses/{participantId} {
          allow read, write: if true;
        }
      }
    }

    // ── 설문 템플릿: 누구나 읽기, 생성/수정은 관리자만 ──
    match /surveyTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 퍼실리테이터 프로필: 읽기 공개, 수정은 인증 필요 ──
    match /facilitators/{uid} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── 관리자 프로필: 인증 필수 ──
    match /admins/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
