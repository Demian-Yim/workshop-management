# Firebase 설정 (필수)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Kakao Map (선택 — 지도 기능 사용 시)
# https://developers.kakao.com 에서 발급
NEXT_PUBLIC_KAKAO_MAP_API_KEY=

# Kakao 로컬 REST API (선택 — 맛집 검색 기능 사용 시)
# Kakao Developers > REST API 키 (서버 전용, 클라이언트에 노출 금지)
KAKAO_REST_API_KEY=

# Gemini API (선택 — AI 캐릭터 생성 사용 시)
# https://aistudio.google.com 에서 발급
GEMINI_API_KEY=

# NanoBanana API (선택 — AI 캐릭터 생성 우선 공급자)
NANOBANANA_API_KEY=
NANOBANANA_API_URL=
